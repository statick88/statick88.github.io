---
// Componente para mostrar capacitaciones certificadas en el portafolio
import cvData from "../../../cv.json"

// Obtener capacitaciones de cv.json
const trainings = (cvData.trainings || []).filter(t => t.verified === true);
---

<section id="trainings" class="section">
  <div class="section-header">
    <h2 class="section-title">Capacitaciones</h2>
    <p class="section-subtitle">Certificaciones y formación continua</p>
  </div>
  
  {trainings.length === 0 ? (
    <div class="no-trainings">
      <p>No hay capacitaciones verificadas disponibles.</p>
    </div>
  ) : (
    <div class="trainings-grid">
      {trainings.map(training => (
        <article class="training-card">
          <div class="training-content">
            <h3 class="training-title">
              {typeof training.name === 'object' 
                ? training.name.es || training.name.en 
                : training.name}
            </h3>
            <div class="training-meta">
              {training.institution && (
                <span class="training-institution">{training.institution}</span>
              )}
              {training.startDate && (
                <span class="training-date">
                  {new Date(training.startDate).toLocaleDateString('es-ES', {
                    year: 'numeric',
                    month: 'long'
                  })}
                </span>
              )}
            </div>
            {training.description && (
              <p class="training-description">
                {typeof training.description === 'object' 
                  ? training.description.es || training.description.en 
                  : training.description}
              </p>
            )}
            {training.url && (
              <a 
                href={training.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="training-link"
              >
                <span>Ver certificado</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14,2 14,8 20,8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10,9 9,9 8,9"></polyline>
                </svg>
              </a>
            )}
            {training.url && (
              <div class="share-buttons">
                <a href={`https://wa.me/?text=${encodeURIComponent(`${typeof training.name === 'object' ? training.name.es || training.name.en : training.name}: ${training.url}`)}`} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp" title="Compartir en WhatsApp">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                    <path d="M9.5 13.5c.48-.12.98-.32 1.4-.61l1.5-1a2 2 0 0 1 2 0l1 1a2 2 0 0 1 0 2l-1 1a2 2 0 0 1-.61 1.4c-.48.12-.98.32-1.4.61l-1 1a2 2 0 0 1-2 0l-1-1a2 2 0 0 1 0-2l1-1a2 2 0 0 1 .61-1.4z"/>
                  </svg>
                </a>
                <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(training.url)}&text=${encodeURIComponent(typeof training.name === 'object' ? training.name.es || training.name.en : training.name)}`} target="_blank" rel="noopener noreferrer" class="btn btn-twitter" title="Compartir en Twitter/X">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
                  </svg>
                </a>
                <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(training.url)}`} target="_blank" rel="noopener noreferrer" class="btn btn-facebook" title="Compartir en Facebook">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                  </svg>
                </a>
                <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(training.url)}`} target="_blank" rel="noopener noreferrer" class="btn btn-linkedin" title="Compartir en LinkedIn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                    <rect x="2" y="9" width="4" height="12"/>
                    <circle cx="4" cy="4" r="2"/>
                  </svg>
                </a>
                <a href={`mailto:?subject=${encodeURIComponent(typeof training.name === 'object' ? training.name.es || training.name.en : training.name)}&body=${encodeURIComponent(`${typeof training.name === 'object' ? training.name.es || training.name.en : training.name}: ${training.url}`)}`} class="btn btn-email" title="Compartir por Email">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                </a>
                <button class="btn btn-share" data-url={training.url} data-name={typeof training.name === 'object' ? training.name.es || training.name.en : training.name} title="Compartir genérico">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="18" cy="5" r="3"></circle>
                    <circle cx="6" cy="12" r="3"></circle>
                    <circle cx="18" cy="19" r="3"></circle>
                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                    <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                  </svg>
                </button>
              </div>
            )}
          </div>
          
          <div class="training-status">
            <span class="verified-badge">✓ Verificado</span>
          </div>
        </article>
      ))}
    </div>
  )}
</section>

<style>
  /* Contenedor principal de la sección */
  .section {
    margin-bottom: 3rem;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .section-title {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  
  .section-subtitle {
    color: var(--color-text-secondary);
    font-size: 1rem;
  }
  
  /* Mensaje cuando no hay capacitaciones */
  .no-trainings {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--color-bg-hover);
    border-radius: 8px;
    color: var(--color-text-secondary);
  }
  
  /* Grid de capacitaciones */
  .trainings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  
  /* Tarjeta de capacitación */
  .training-card {
    background: var(--color-bg-hover);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    position: relative;
    overflow: hidden;
  }
  
  .training-card:hover {
    transform: translateY(-2px);
    border-color: #007acc;
  }
  
  .training-content {
    margin-bottom: 1rem;
  }
  
  .training-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  
  .training-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }
  
  .training-institution {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
  }
  
  .training-date {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
  }
  
  .training-description {
    color: var(--color-text);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  
  .training-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #007acc;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s ease;
    margin-bottom: 0.75rem;
  }
  
  .training-link:hover {
    color: #005a9e;
    text-decoration: underline;
  }
  
  .training-status {
    position: absolute;
    top: 1rem;
    right: 1rem;
  }
  
  .verified-badge {
    background: #28a745;
    color: white;
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 12px;
    font-weight: 500;
  }

  /* Share buttons */
  .share-buttons {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.65rem;
    border-radius: 5px;
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-whatsapp {
    background: #25D366;
    border: 1px solid #25D366;
    color: white;
    cursor: pointer;
  }

  .btn-whatsapp:hover {
    background: #128C7E;
    border-color: #128C7E;
  }

  .btn-twitter {
    background: #1DA1F2;
    border: 1px solid #1DA1F2;
    color: white;
    cursor: pointer;
  }

  .btn-twitter:hover {
    background: #0D8BD9;
    border-color: #0D8BD9;
  }

  .btn-facebook {
    background: #1877F2;
    border: 1px solid #1877F2;
    color: white;
    cursor: pointer;
  }

  .btn-facebook:hover {
    background: #0C5FCC;
    border-color: #0C5FCC;
  }

  .btn-linkedin {
    background: #0077B5;
    border: 1px solid #0077B5;
    color: white;
    cursor: pointer;
  }

  .btn-linkedin:hover {
    background: #005885;
    border-color: #005885;
  }

  .btn-email {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
  }

  .btn-email:hover {
    border-color: var(--color-text-secondary);
    background: var(--color-bg-hover);
  }

  .btn-share {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
  }

  .btn-share:hover {
    border-color: var(--color-text-secondary);
    background: var(--color-bg-hover);
  }
  
  /* Responsive */
  @media (width <= 768px) {
    .section-title {
      font-size: 1.5rem;
    }
    
    .trainings-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .training-card {
      padding: 1rem;
    }
    
    .training-status {
      position: static;
      margin-top: 1rem;
      text-align: right;
    }
  }
  
  @media print {
    .training-link {
      display: none;
    }
      
    .verified-badge {
      background: #28a745;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .share-buttons {
      display: none;
    }
  }
</style>

<script type="module" src="./../../scripts/trainings-share.js"></script>
