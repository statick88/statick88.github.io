---
import Section from "../Section.astro"
import { projects } from "@cv"

const sortedProjects = [...projects]
  .sort((a, b) => {
    return 0;
  })
  .slice(0, 6)

function isWebpImage(path?: string): boolean {
  return typeof path === "string" && path.endsWith(".webp")
}

function isGitHub(url: string): boolean {
  return url.includes("github.com")
}

function getDomain(url: string): string {
  try {
    const domain = new URL(url).hostname
    return domain.replace("www.", "")
  } catch {
    return "sitio web"
  }
}
---

<Section title="Portafolio" i18nKey="section.portfolio">
  <div class="projects-grid">
    {
      sortedProjects.map(
        ({ name, description, highlights, url, github, image, isActive }, index) => {
          return (
            <article class="project-card">
              {image && (
                <div class="project-image">
                  {isWebpImage(image) ? (
                    <picture>
                      <source srcset={`${image.replace('.webp', '.avif')} 400w, ${image.replace('.webp', '.avif')} 800w`} sizes="(max-width: 700px) 100vw, 400px" type="image/avif" />
                      <source srcset={`${image} 400w, ${image} 800w`} sizes="(max-width: 700px) 100vw, 400px" type="image/webp" />
                      <img src={image} alt={name} loading="lazy" decoding="async" width="400" height="225" />
                    </picture>
                  ) : (
                    <img src={image} alt={name} loading="lazy" decoding="async" width="400" height="225" />
                  )}
                </div>
              )}
              <header>
                <div class="project-header">
                  <h3>
                    <a href={url} title={`Ver ${name}`} target="_blank" rel="noopener noreferrer">
                      {name}
                    </a>
                  </h3>
                  {isActive && <span class="active-badge" data-i18n="portfolio.active">Activo</span>}
                </div>
              </header>

              <footer>
                <p class="project-description" data-i18n={`cv.projects.${index}.description`}>{description}</p>
                {highlights && typeof highlights === 'object' && 'es' in highlights && (
                  <ul class="project-highlights">
                    {(highlights.es || []).map((highlight, hIndex) => (
                      <li data-i18n={`cv.projects.${index}.highlights.${hIndex}`}>{highlight}</li>
                    ))}
                  </ul>
                )}
                 <div class="project-links">
                    <a href={url} target="_blank" rel="noopener noreferrer" class="btn btn-deploy">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                        <polyline points="15 3 21 3 21 9"></polyline>
                        <line x1="10" y1="14" x2="21" y2="3"></line>
                      </svg>
                      <span>{getDomain(url)}</span>
                    </a>
                    {github && github !== url && (
                      <a href={github} target="_blank" rel="noopener noreferrer" class="btn btn-github">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                        <span>GitHub</span>
                      </a>
                    )}
                     {index === 0 && (
                      <div class="share-buttons">
                        <a href={`https://wa.me/?text=${encodeURIComponent(`${name}: ${url}`)}`} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp" title="Compartir en WhatsApp">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                            <path d="M9.5 13.5c.48-.12.98-.32 1.4-.61l1.5-1a2 2 0 0 1 2 0l1 1a2 2 0 0 1 0 2l-1 1a2 2 0 0 1-.61 1.4c-.48.12-.98.32-1.4.61l-1 1a2 2 0 0 1-2 0l-1-1a2 2 0 0 1 0-2l1-1a2 2 0 0 1 .61-1.4z"/>
                          </svg>
                        </a>
                        <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(name)}`} target="_blank" rel="noopener noreferrer" class="btn btn-twitter" title="Compartir en Twitter/X">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
                          </svg>
                        </a>
                        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`} target="_blank" rel="noopener noreferrer" class="btn btn-facebook" title="Compartir en Facebook">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                          </svg>
                        </a>
                        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`} target="_blank" rel="noopener noreferrer" class="btn btn-linkedin" title="Compartir en LinkedIn">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                            <rect x="2" y="9" width="4" height="12"/>
                            <circle cx="4" cy="4" r="2"/>
                          </svg>
                        </a>
                        <a href={`mailto:?subject=${encodeURIComponent(name)}&body=${encodeURIComponent(`${name}: ${url}`)}`} class="btn btn-email" title="Compartir por Email">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                          </svg>
                        </a>
                        <button class="btn btn-share" data-url={url} data-name={name} title="Compartir genérico">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="18" cy="5" r="3"></circle>
                            <circle cx="6" cy="12" r="3"></circle>
                            <circle cx="18" cy="19" r="3"></circle>
                            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                          </svg>
                        </button>
                      </div>
                    )}
                  </div>
              </footer>
            </article>
          )
        }
      )
    }
  </div>
</Section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1rem;
  }

  .project-card {
    background: var(--color-bg-hover);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-text-secondary);
  }

  .project-image {
    margin: -1rem -1rem 0.75rem -1rem;
    border-radius: 8px 8px 0 0;
    overflow: hidden;
    aspect-ratio: 16/9;
    background: var(--color-bg);
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .project-card h3 {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
    margin: 0;
  }

  .project-card a {
    color: var(--color-text);
    text-decoration: none;
  }

  .project-card a:hover {
    text-decoration: underline;
  }

  .active-badge {
    background: #1a7f37;
    color: white;
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border-radius: 10px;
    font-weight: 500;
    white-space: nowrap;
  }

  .project-description {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    flex-grow: 1;
  }

  .project-highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem 0;
  }

  .project-highlights li {
    color: var(--color-text);
    font-size: 0.8rem;
    padding: 0.15rem 0;
    padding-left: 1rem;
    position: relative;
  }

  .project-highlights li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--color-text-secondary);
  }

  .project-links {
    display: flex;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.65rem;
    border-radius: 5px;
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-deploy {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-deploy:hover {
    border-color: var(--color-text-secondary);
    background: var(--color-bg-hover);
  }

  .btn-github {
    background: #24292e;
    border: 1px solid #24292e;
    color: white;
  }

  .btn-github:hover {
    background: #2f363d;
    border-color: #2f363d;
  }

  .share-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .btn-whatsapp {
    background: #25D366;
    border: 1px solid #25D366;
    color: white;
    cursor: pointer;
  }

  .btn-whatsapp:hover {
    background: #128C7E;
    border-color: #128C7E;
  }

  .btn-twitter {
    background: #1DA1F2;
    border: 1px solid #1DA1F2;
    color: white;
    cursor: pointer;
  }

  .btn-twitter:hover {
    background: #0D8BD9;
    border-color: #0D8BD9;
  }

  .btn-facebook {
    background: #1877F2;
    border: 1px solid #1877F2;
    color: white;
    cursor: pointer;
  }

  .btn-facebook:hover {
    background: #0C5FCC;
    border-color: #0C5FCC;
  }

  .btn-linkedin {
    background: #0077B5;
    border: 1px solid #0077B5;
    color: white;
    cursor: pointer;
  }

  .btn-linkedin:hover {
    background: #005885;
    border-color: #005885;
  }

  .btn-email {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
  }

  .btn-email:hover {
    border-color: var(--color-text-secondary);
    background: var(--color-bg-hover);
  }

  .btn-share {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
  }

  .btn-share:hover {
    border-color: var(--color-text-secondary);
    background: var(--color-bg-hover);
  }

  @media (width <= 700px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script type="module" src="/scripts/trainings-share.js"></script>
