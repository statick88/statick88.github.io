---
interface Props {
  class?: string
}

const { class: className = "" } = Astro.props

const COFFEE_ICON = `
  <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="margin-right: 8px" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M17 8h1a4 4 0 1 1 0 8h-1"></path>
    <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path>
    <line x1="6" y1="2" x2="6" y2="4"></line>
    <line x1="10" y1="2" x2="10" y2="4"></line>
    <line x1="14" y1="2" x2="14" y2="4"></line>
  </svg>
`;
---

<a 
  href="https://paypal.me/dsaavedra88" 
  target="_blank" 
  rel="noopener noreferrer"
  aria-label="Invítame un café"
  class={className}
  role="button"
  tabindex="0"
>
  <span set:html={COFFEE_ICON}></span>
  <span data-i18n="coffee.text">Café</span>
</a>

<style>
  a {
    position: fixed;
    top: 1rem;
    left: 2rem;
    background: linear-gradient(135deg, #ff813f, #e6560e);
    border: 1px solid #e6560e;
    color: #fff;
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s ease;
    z-index: 9999;
    box-shadow: 0 2px 8px rgba(230, 86, 14, 0.3);
    text-decoration: none;
    font-weight: 600;
  }

  a:focus {
    outline: 2px solid #ff813f;
    outline-offset: 2px;
  }

  a:hover {
    transform: scale(1.05);
    background: linear-gradient(135deg, #e6560e, #cc4400);
    box-shadow: 0 4px 12px rgba(230, 86, 14, 0.4);
  }

  a svg {
    width: 16px;
    height: 16px;
  }

  @media print {
    a { 
      display: none; 
    }
  }

  @media (max-width: 500px) {
    a {
      left: 1.5rem;
      padding: 0.4rem 0.6rem;
      font-size: 0.8rem;
    }

    a span:first-child {
      margin-right: 6px;
    }
  }

  @media (max-width: 400px) {
    a {
      left: 1.5rem;
      top: 1rem;
    }
  }

  @media (max-width: 320px) {
    a {
      left: 1rem;
      right: 1rem;
      top: 1rem;
      width: auto;
    }
  }
</style>
