<button id="theme-toggle" aria-label="Cambiar tema">
  <span class="theme-icon">🌙</span>
</button>

<script type="module" src="/scripts/theme-toggle.js"></script>

<style>
  button {
    position: fixed;
    top: 1rem;
    right: 4rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    z-index: 9999;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  }

  button:hover {
    transform: scale(1.1);
    background: var(--color-bg-hover);
  }

  /* Lógica para mostrar/ocultar iconos según el tema */
  .sun-icon { display: none; }
  .moon-icon { display: block; }

  /* :global() es necesario porque la clase 'dark' está en el tag <html> */
  :global(.dark) .sun-icon { display: block; }
  :global(.dark) .moon-icon { display: none; }
  
  @media print {
    button { display: none; }
  }

  @media (max-width: 500px) {
    button {
      right: 3rem;
      width: 32px;
      height: 32px;
    }
  }
</style>
