---
import cvData from "../../cv.json"
import ThemeToggle from "@/components/ThemeToggle.astro"
import LanguageToggle from "@/components/LanguageToggle.astro"
import CyberButton from "@/components/CyberButton.astro"
import EbookButton from "@/components/EbookButton.astro"
import CoffeeButton from "@/components/CoffeeButton.astro"
import CvDownloadButton from "@/components/CvDownloadButton.astro"

interface Props {
  title: string
  preconnects?: { href: string; crossorigin?: boolean }[]
}

const { title, preconnects = [] } = Astro.props

const { image, summary, url } = cvData.basics
const summaryText = typeof summary === 'object' ? summary.es : summary
const { basics, work, education, publications, projects } = cvData
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summaryText} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preload critical resources for LCP -->
    <link rel="preload" href="/me.webp" as="image" type="image/webp" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    {preconnects.map((p) => (
      <link rel="preconnect" href={p.href} {...p.crossorigin ? { crossorigin: "" } : {}} />
    ))}

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summaryText} />
    <meta property="og:image" content={image} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={url.split("//")[1] ?? ''} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summaryText} />
    <meta name="twitter:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Portfolio Diego Saavedra" />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://statick88.github.io/" />
    
    <!-- Author -->
    <meta name="author" content="Diego Medardo Saavedra García" />
    
    <!-- Keywords -->
    <meta name="keywords" content="Full Stack Developer, Python Developer, React Developer, Django, FastAPI, JavaScript, TypeScript, Educador, Bootcamp Instructor, Linux, Ecuador" />
    
    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#4c80cc" />

    <!-- Structured Data for SEO -->
    <script type="application/ld+json" is:inline>
    {{
      "@context": "https://schema.org",
      "@type": "Person",
      "name": basics.name,
      "jobTitle": typeof basics.label === 'object' ? basics.label.es : basics.label,
      "email": "dsaavedra88@gmail.com",
      "telephone": "+593 980192790",
      "url": basics.url,
      "image": image,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": basics.location?.city || "Loja",
        "addressCountry": basics.location?.countryCode || "EC"
      },
      "sameAs": [
        "https://www.linkedin.com/in/diego-saavedra-developer/",
        "https://github.com/statick88",
        "https://x.com/statick_ds"
      ],
      "knowsAbout": work.map(w => w.name).concat(education.map(e => e.institution)).filter(Boolean),
      "description": summaryText
    }}
    </script>

    <!-- External scripts -->
    <script type="module" src="/scripts/theme.js"></script>
    <script type="module" src="/scripts/lang.js"></script>

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ERTFC8RLNR"></script>
    <script type="module" src="/scripts/analytics.js"></script>
  </head>
  <body>
    <slot />
    <LanguageToggle />
    <ThemeToggle />
    <CoffeeButton />
    <CvDownloadButton />
    <CyberButton />
    <EbookButton />

    <script type="module" define:vars={{ basics, work, education, publications, projects }}>
      import { setCvData } from '/scripts/cv-data.js';
      setCvData({
        basics: basics,
        work: work,
        education: education,
        publications: publications,
        projects: projects
      });
    </script>

    <script type="module" src="/scripts/i18n.js"></script>
  </body>
</html>

<style is:global>
  /* Definimos las variables de color para ambos temas */
  :root {
    --color-bg: #fff;
    --color-bg-hover: #f4f4f4;
    --color-text: #000;
    --color-text-secondary: #444;
    --color-border: #ddd;
    --color-accent: #4c80cc;
  }

  /* VARIABLES PARA EL AZUL OSCURO */
  html.dark {
    --color-bg: #0a0e1a; /* Azul oscuro profundo */
    --color-bg-hover: #1b243d;
    --color-text: #ffffff;
    --color-text-secondary: #b8b8b8;
    --color-border: #2a2a2a;
    --color-accent: #4c80cc;
  }

  html {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    /* Usamos la variable en lugar del color fijo */
    background: var(--color-bg);
    color: var(--color-text);
    letter-spacing: -0.025rem;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    color: var(--color-text); /* Asegura que los títulos usen la variable */
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  p {
    color: var(--color-text-secondary); /* Usamos la variable */
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    text-wrap: pretty;
    text-align: justify;
  }

  /* Términos técnicos con JetBrains Mono */
  code,
  .tech-term {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.9em;
    background: var(--color-bg-hover);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }

  .print {
    display: none !important;
  }

  @media print {
    /* Forzamos modo claro al imprimir */
    :root {
      --color-bg: #fff !important;
      --color-text: #000 !important;
      --color-text-secondary: #555 !important;
    }
    
    html {
      background: #fff !important;
      color: #000 !important;
    }

    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    astro-dev-toolbar {
      display: none !important;
    }

    article {
      break-inside: avoid;
    }
  }
</style>
